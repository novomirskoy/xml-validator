{
    "name": "novomirskoy/xml-validator",
    "license": "proprietary",
    "type": "library",
    "require": {
        "php": "^8.5",
        "ext-dom": "*",
        "ext-libxml": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpunit/phpunit": "13.*",
        "roave/security-advisories": "dev-latest"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Novomirskoy\\XmlValidator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Novomirskoy\\XmlValidator\\": "tests/"
        }
    },
    "config": {
        "bump-after-update": "dev",
        "optimize-autoloader": true,
        "platform": {
            "php": "8.5"
        },
        "sort-packages": true,
        "lock": false
    },
    "scripts": {
        "test": "phpunit --colors=always --testdox",
        "fixer": "php-cs-fixer fix --allow-risky=yes --diff",
        "fixer:dry": "php-cs-fixer fix --allow-risky=yes --diff --dry-run"
    }
}
